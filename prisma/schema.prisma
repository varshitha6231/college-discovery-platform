generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model College {
  id        String   @id @default(cuid())
  name      String
  location  String
  state     String
  type      String
  ranking   Int?
  fees      Int?
  createdAt DateTime @default(now())
}